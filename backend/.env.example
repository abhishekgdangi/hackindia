# ─── MongoDB ───────────────────────────────────────────────────────
# Local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/hackindia
# MongoDB Atlas (production)
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hackindia

# ─── Groq API (FREE — https://console.groq.com) ────────────────────
# Sign up free at console.groq.com → API Keys → Create Key
# Free tier: 14,400 requests/day, 500,000 tokens/minute — no credit card needed
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ADMIN_SECRET=change_this_secret_in_production

# ─── Scraping Settings ─────────────────────────────────────────────
SCRAPE_INTERVAL_HOURS=6
PUPPETEER_HEADLESS=true
REQUEST_DELAY_MS=2000
MAX_RETRIES=3

# ─── Optional Platform API Keys (improve scrape quality) ───────────
HACKEREARTH_CLIENT_ID=
HACKEREARTH_CLIENT_SECRET=
DEVPOST_API_KEY=
